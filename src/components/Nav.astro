---
import { SITE, SERVICES, SUBURBS } from '../data/site';
---
<div class="topbar">
  <div class="container">
    <span>Serving Des Moines, IA and Surrounding Areas · Licensed and Insured</span>
    <span>24/7 Emergency Service: <a href={`tel:${SITE.phoneTel}`}>{SITE.phone}</a></span>
  </div>
</div>
<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Des Moines Septic">
      <img src="/logo.webp" alt="Des Moines Septic" width="400" height="300" />
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/">Home</a></li>
      <li class="dropdown">
        <a href="/services/">Services</a>
        <ul class="dropdown-menu">
          {SERVICES.map(s => <li><a href={`/${s.slug}/`}>{s.title}</a></li>)}
        </ul>
      </li>
      <li class="dropdown">
        <a href="/service-area/">Locations</a>
        <ul class="dropdown-menu">
          {SUBURBS.map(s => <li><a href={`/${s.slug}/`}>{s.name}, IA</a></li>)}
        </ul>
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
    <div class="header-cta">
      <a href={`tel:${SITE.phoneTel}`} class="header-phone">{SITE.phone}</a>
      <a href="/contact/" class="btn">Request Service</a>
      <button class="mobile-toggle" id="navToggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="navLinks">☰</button>
    </div>
  </div>
</header>
<script>
  const t = document.getElementById('navToggle');
  const l = document.getElementById('navLinks');
  const isMobile = () => window.innerWidth <= 920;
  const setState = (open: boolean) => {
    if (!l || !t) return;
    l.classList.toggle('open', open);
    t.setAttribute('aria-expanded', String(open));
    t.textContent = open ? '✕' : '☰';
    if (!open) {
      l.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open'));
    }
  };
  t?.addEventListener('click', () => setState(!l?.classList.contains('open')));

  // On mobile, tapping a dropdown's top-level label toggles the submenu instead of navigating.
  l?.querySelectorAll('.dropdown > a').forEach(a => {
    a.addEventListener('click', (e) => {
      if (!isMobile() || !l.classList.contains('open')) return;
      e.preventDefault();
      const parent = a.parentElement;
      const wasOpen = parent?.classList.contains('open');
      l.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open'));
      if (!wasOpen) parent?.classList.add('open');
    });
  });

  // Tapping any leaf link (not a dropdown parent) closes the menu.
  l?.querySelectorAll('a').forEach(a => {
    if (a.parentElement?.classList.contains('dropdown')) return;
    a.addEventListener('click', () => setState(false));
  });

  window.addEventListener('resize', () => {
    if (!isMobile()) setState(false);
  });
</script>
