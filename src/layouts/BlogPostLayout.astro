---
import Layout from './Layout.astro';
import { SITE } from '../data/site';
import { BLOG_POSTS } from '../data/blog-posts';

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const post = BLOG_POSTS.find(p => p.slug === slug);
if (!post) throw new Error(`Blog post not found: ${slug}`);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,
  "datePublished": post.publishDate,
  "dateModified": post.publishDate,
  "author": { "@type": "Organization", "name": SITE.name, "url": `https://${SITE.domain}/` },
  "publisher": { "@type": "Organization", "name": SITE.name, "logo": { "@type": "ImageObject", "url": `https://${SITE.domain}/logo.webp` } },
  "image": post.image ? `https://${SITE.domain}${post.image}` : `https://${SITE.domain}/og.jpg`,
  "mainEntityOfPage": `https://${SITE.domain}/blog/${post.slug}/`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `https://${SITE.domain}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `https://${SITE.domain}/blog/` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `https://${SITE.domain}/blog/${post.slug}/` }
  ]
};

const related = BLOG_POSTS.filter(p => p.slug !== slug).slice(0, 3);

const formattedDate = new Date(post.publishDate + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={post.title} description={post.description} schema={[articleSchema, breadcrumbSchema]}>
  <section class="section blog-post-section">
    <div class="container blog-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>›</span> <a href="/blog/">Blog</a> <span>›</span> <span>{post.title}</span>
      </nav>
      <article class="blog-post">
        <header class="blog-post-header">
          <h1>{post.title}</h1>
          <p class="blog-post-meta">Published {formattedDate} · {post.readMinutes} min read</p>
          {post.image && <img src={post.image} alt={post.imageAlt} class="blog-post-hero" width="1400" height="788" loading="eager" fetchpriority="high" decoding="async" />}
        </header>
        <div class="blog-post-body">
          <slot />
        </div>
        <aside class="blog-cta">
          <h3>Need septic service in the Des Moines metro?</h3>
          <p>We provide septic tank pumping, cleaning, repair, emergency service, and Iowa Time of Transfer inspections across Polk, Dallas, Warren, and Madison Counties.</p>
          <p><a href={`tel:${SITE.phoneTel}`} class="btn">Call {SITE.phone}</a> <a href="/contact/" class="btn btn-outline">Request a Quote</a></p>
        </aside>
      </article>
      {related.length > 0 && (
        <section class="related-posts">
          <h2>More From the Blog</h2>
          <div class="related-grid">
            {related.map(r => (
              <a href={`/blog/${r.slug}/`} class="related-card">
                {r.image && <img src={r.image} alt={r.imageAlt} loading="lazy" decoding="async"  width="1400" height="788" />}
                <div class="related-card-body">
                  <h3>{r.title}</h3>
                  <p>{r.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</Layout>
