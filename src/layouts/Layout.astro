---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: any;
  heroImage?: string;
}
const { title, description, canonical, schema, heroImage } = Astro.props;
const preloadHero = heroImage || '/images/septic-tank-pumping-des-moines.webp';
const url = canonical || `https://${SITE.domain}${Astro.url.pathname}`;

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://${SITE.domain}/#business`,
  "name": SITE.name,
  "image": `https://${SITE.domain}/logo.webp`,
  "url": `https://${SITE.domain}/`,
  "telephone": SITE.phone,
  "priceRange": "$$",
  "areaServed": ["Des Moines, IA", "West Des Moines, IA", "Ankeny, IA", "Waukee, IA", "Norwalk, IA"],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 41.5868, "longitude": -93.6250 }
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta name="msvalidate.01" content="39B504B2FB7466B6FB6F9378A3D24496" />
  <meta name="yandex-verification" content="0723ade4568febf7" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" sizes="512x512" href="/favicon-512.png" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:image" content={`https://${SITE.domain}/og.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://${SITE.domain}/og.jpg`} />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="image" href={preloadHero} fetchpriority="high" />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&amp;family=Open+Sans:wght@400;600;700&amp;display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&amp;family=Open+Sans:wght@400;600;700&amp;display=swap" rel="stylesheet" /></noscript>
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
  {schema && (Array.isArray(schema)
    ? schema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
    : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
