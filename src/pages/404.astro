---
import Layout from '../layouts/Layout.astro';
import { SITE, SERVICES, SUBURBS } from '../data/site';
const title = "Page Not Found | Des Moines Septic";
const description = "The page you're looking for can't be found. Call (515) 303-4896 for fast local septic service across the Des Moines metro.";
---
<Layout {title} {description}>
  <section class="hero">
    <div class="container">
      <h1>Page Not Found</h1>
      <p class="lead">We couldn't find the page you were looking for. Need septic service? We're a phone call away.</p>
      <a href={`tel:${SITE.phoneTel}`} class="hero-phone">📞 {SITE.phone}</a>
      <div class="hero-cta">
        <a href={`tel:${SITE.phoneTel}`} class="btn btn-lg">Call Now</a>
        <a href="/" class="btn btn-outline btn-lg" style="background:transparent;color:#fff;border-color:#fff">Back to Home</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <h2>Looking for one of these?</h2>
      <h3 style="margin-top:24px">Services</h3>
      <ul class="checks">
        {SERVICES.map(s => <li><a href={`/${s.slug}/`}>{s.title}</a></li>)}
      </ul>
      <h3 style="margin-top:24px">Service Areas</h3>
      <ul class="checks">
        {SUBURBS.map(s => <li><a href={`/${s.slug}/`}>Septic Service in {s.name}, IA</a></li>)}
      </ul>
    </div>
  </section>
</Layout>
